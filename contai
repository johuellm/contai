#!/bin/bash 
set -eu

tool=$(basename "$0")

if test "$tool" = "contai"
then
	tool=
fi

data_dir=~/.local/share/contai

home_dir=$data_dir/home
env_file="$data_dir/env.list"

mkdir -p "$home_dir"
touch "$env_file"

docker run \
	--rm \
	-it \
	--user $(id -un):$(id -gn) \
	--cap-drop=ALL \
	--security-opt=no-new-privileges \
	--env-file "$env_file" \
	--pids-limit 512 \
	--memory 8g \
 	-v "$home_dir:$HOME" \
	-v "$PWD:/workspace:rw" \
	-w "/workspace" \
	-p 5080:5080 \
	-p 8080:8080 \
	contai:latest \
	/usr/local/bin/contai-bootstrap \
	$tool \
	"$@"


